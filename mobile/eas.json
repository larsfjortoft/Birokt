{
  "cli": {
    "version": ">= 7.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.birokt.no/api/v1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.birokt.no/api/v1",
        "EXPO_PUBLIC_SENTRY_DSN": ""
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
