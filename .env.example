# BirÃ¸kt System - Environment Variables Template
# Copy this file to .env and fill in your values

# ======================
# APPLICATION
# ======================
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ======================
# DATABASE (SQLite for development)
# ======================
DATABASE_URL="file:./dev.db"

# For PostgreSQL (production):
# DATABASE_URL=postgresql://birokt:birokt_dev_password@localhost:5432/birokt

# ======================
# JWT AUTHENTICATION
# ======================
JWT_SECRET=replace-with-at-least-32-characters-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# ======================
# FILE STORAGE
# ======================
# For local development, files are stored in ./uploads
# CDN_URL is used as base URL for photo URLs
CDN_URL=http://localhost:3000/uploads

# For production (S3/MinIO):
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=birokt-photos
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1

# ======================
# CORS
# ======================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:19006,exp://localhost:8081

# ======================
# LOGGING
# ======================
LOG_LEVEL=debug

# ======================
# WEB FRONTEND (for Next.js - in frontend-web/.env.local)
# ======================
# NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# NEXT_PUBLIC_CDN_URL=http://localhost:3000/uploads

# ======================
# MOBILE APP (for Expo - in mobile/.env)
# ======================
# EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# ======================
# EMAIL (optional)
# ======================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass
# SMTP_FROM=noreply@birokt.no
