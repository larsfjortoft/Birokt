# Birøkt System - Environment Variables Template
# Copy this file to .env and fill in your values

# ======================
# APPLICATION
# ======================
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ======================
# DATABASE
# ======================
DATABASE_URL=postgresql://birokt:birokt_dev_password@localhost:5432/birokt

# For Prisma connection pooling (optional)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ======================
# JWT AUTHENTICATION
# ======================
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# ======================
# FILE STORAGE (S3 / MinIO)
# ======================
# For local development (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=birokt-photos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# For production (AWS S3 or Cloudflare R2)
# S3_ENDPOINT=https://s3.eu-west-1.amazonaws.com
# S3_BUCKET=birokt-photos
# S3_ACCESS_KEY=your-aws-access-key
# S3_SECRET_KEY=your-aws-secret-key
# S3_REGION=eu-west-1
# S3_FORCE_PATH_STYLE=false

# CDN URL for serving images (optional)
CDN_URL=http://localhost:9000

# ======================
# REDIS (Optional - for caching)
# ======================
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=birokt:

# ======================
# EXTERNAL APIs
# ======================
# Weather API (Norwegian Meteorological Institute)
WEATHER_API_URL=https://api.met.no/weatherapi
WEATHER_API_USER_AGENT=Birokt/1.0 (your-email@example.com)

# ======================
# CORS (Cross-Origin Resource Sharing)
# ======================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:19006,exp://localhost:8081

# ======================
# RATE LIMITING
# ======================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ======================
# MONITORING & LOGGING
# ======================
# Sentry (Error tracking)
SENTRY_DSN=

# Log level: debug, info, warn, error
LOG_LEVEL=debug

# ======================
# EMAIL (Optional - for notifications)
# ======================
# SMTP settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Birøkt
SMTP_FROM_EMAIL=noreply@birokt.no

# ======================
# BACKGROUND JOBS (Optional)
# ======================
# Bull queue settings
BULL_REDIS_URL=redis://localhost:6379
BULL_PREFIX=birokt:bull:

# ======================
# FEATURE FLAGS (Optional)
# ======================
ENABLE_WEATHER_INTEGRATION=true
ENABLE_AI_IMAGE_ANALYSIS=false
ENABLE_PUSH_NOTIFICATIONS=false

# ======================
# MOBILE APP (for Expo)
# ======================
# These should be in mobile/.env or mobile/app.config.js
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_CDN_URL=http://localhost:9000
EXPO_PUBLIC_SENTRY_DSN=

# ======================
# WEB FRONTEND (for Next.js)
# ======================
# These should be in frontend-web/.env.local
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_CDN_URL=http://localhost:9000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ANALYTICS_ID=

# ======================
# DEVELOPMENT ONLY
# ======================
# Enable hot module replacement
HMR_ENABLED=true

# Pretty print logs
LOG_PRETTY=true

# Seed database on startup
AUTO_SEED=false

# ======================
# PRODUCTION ONLY
# ======================
# These are typically set in your hosting provider's dashboard

# Database connection string (from hosting provider)
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# S3 / R2 credentials (from cloud provider)
# S3_ENDPOINT=https://your-bucket.r2.cloudflarestorage.com
# S3_ACCESS_KEY=your-production-access-key
# S3_SECRET_KEY=your-production-secret-key

# JWT secret (generate a strong random string)
# JWT_SECRET=use-openssl-rand-base64-32-to-generate

# Sentry DSN (from sentry.io)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Redis URL (from hosting provider)
# REDIS_URL=redis://default:password@host:6379

# CORS origins (your production domains)
# CORS_ORIGINS=https://app.birokt.no,https://birokt.no
